<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BioBriefing — Student Biotechnology Updates</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper: #F1F3EE;
    --paper-raised: #FBFCF9;
    --ink: #1B2A22;
    --ink-soft: #4A5B50;
    --line: #C9CDBE;
    --line-strong: #9AA491;

    --c-genomics: #2B5B84;
    --c-genomics-bg: #E3EBF1;
    --c-editing: #2F6F4E;
    --c-editing-bg: #E1EDE5;
    --c-vaccines: #A9791E;
    --c-vaccines-bg: #F1E9D3;
    --c-bioinfo: #5B4B8A;
    --c-bioinfo-bg: #E9E4F2;
    --c-careers: #1F7A6C;
    --c-careers-bg: #DFEFEA;
    --c-funding: #8A3B3B;
    --c-funding-bg: #F1DEDE;

    --radius: 3px;
    --shadow: 0 1px 0 rgba(27,42,34,0.06), 0 6px 16px -8px rgba(27,42,34,0.18);
  }

  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'IBM Plex Sans', sans-serif;
    line-height:1.5;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 34px 34px;
    background-position: -1px -1px;
  }
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.01ms !important; transition-duration:0.01ms !important;}
  }

  .wrap{max-width:1080px; margin:0 auto; padding:0 24px;}

  a{color:inherit;}

  /* ---------- HEADER ---------- */
  header.site{
    position:sticky; top:0; z-index:40;
    background:rgba(241,243,238,0.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line-strong);
  }
  .site-bar{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 24px;
    max-width:1080px; margin:0 auto;
  }
  .brand{display:flex; align-items:center; gap:10px;}
  .brand-mark{
    width:30px; height:30px; border-radius:50%;
    background: radial-gradient(circle at 35% 30%, #4A8A63, var(--c-editing) 60%, #1B4632 100%);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.15);
    flex-shrink:0;
  }
  .brand-text{
    font-family:'Fraunces', serif; font-weight:600; font-size:19px; letter-spacing:-0.01em;
  }
  .site-nav{display:flex; gap:22px; font-family:'IBM Plex Mono', monospace; font-size:12.5px; letter-spacing:0.04em; text-transform:uppercase;}
  .site-nav a{text-decoration:none; color:var(--ink-soft); border-bottom:1px solid transparent; padding-bottom:3px;}
  .site-nav a:hover{color:var(--ink); border-bottom-color:var(--ink);}

  /* ---------- HERO ---------- */
  .hero{padding:56px 24px 40px;}
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px; letter-spacing:0.14em; text-transform:uppercase;
    color:var(--ink-soft);
    display:flex; align-items:center; gap:10px;
    margin-bottom:18px;
  }
  .eyebrow::before{
    content:''; width:7px; height:7px; background:var(--c-editing); border-radius:50%;
    box-shadow:0 0 0 3px var(--c-editing-bg);
  }
  h1.headline{
    font-family:'Fraunces', serif; font-weight:600; font-size:56px; line-height:1.02;
    margin:0 0 18px; max-width:11ch; letter-spacing:-0.015em;
  }
  .sub{font-size:18px; color:var(--ink-soft); max-width:52ch; margin:0 0 30px;}

  .hero-meta{display:flex; gap:28px; flex-wrap:wrap; font-family:'IBM Plex Mono', monospace; font-size:13px; color:var(--ink-soft);}
  .hero-meta strong{color:var(--ink); font-weight:600;}

  /* ---------- FEATURED SPECIMEN CARD ---------- */
  .featured{
    margin-top:38px;
    background:var(--paper-raised);
    border:1px solid var(--line-strong);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    display:grid;
    grid-template-columns:14px 1fr;
    overflow:hidden;
  }
  .featured .tab{background:var(--tab-color, var(--c-editing));}
  .featured .body{padding:28px 30px 30px;}
  .featured-label{
    font-family:'IBM Plex Mono', monospace; font-size:11.5px; letter-spacing:0.1em; text-transform:uppercase;
    color:var(--ink-soft); display:flex; gap:14px; align-items:center; margin-bottom:14px;
  }
  .pin{color:var(--c-funding); font-weight:600;}
  .featured h2{font-family:'Fraunces', serif; font-size:28px; font-weight:600; margin:0 0 10px; letter-spacing:-0.01em;}
  .featured p.excerpt{color:var(--ink-soft); font-size:15.5px; max-width:65ch; margin:0 0 18px;}
  .read-link{
    font-family:'IBM Plex Mono', monospace; font-size:12.5px; text-transform:uppercase; letter-spacing:0.06em;
    text-decoration:none; border-bottom:1px solid var(--ink); padding-bottom:2px; cursor:pointer;
  }

  /* ---------- FILTER BAR ---------- */
  .filter-bar{
    padding:30px 24px 18px;
    display:flex; flex-wrap:wrap; gap:10px; align-items:center;
    border-top:1px solid var(--line);
    margin-top:10px;
  }
  .chip{
    font-family:'IBM Plex Mono', monospace; font-size:12px; letter-spacing:0.04em; text-transform:uppercase;
    padding:7px 13px; border-radius:20px; border:1px solid var(--line-strong);
    background:var(--paper-raised); color:var(--ink-soft); cursor:pointer;
    transition:background .15s, color .15s, border-color .15s;
  }
  .chip:hover{border-color:var(--ink-soft);}
  .chip.active{background:var(--ink); color:var(--paper); border-color:var(--ink);}
  .search-wrap{margin-left:auto; position:relative; min-width:220px;}
  #search{
    width:100%;
    font-family:'IBM Plex Sans', sans-serif; font-size:14px;
    padding:9px 14px 9px 34px;
    border:1px solid var(--line-strong); border-radius:20px;
    background:var(--paper-raised); color:var(--ink);
  }
  #search:focus{outline:2px solid var(--c-editing); outline-offset:1px;}
  .search-wrap::before{
    content:'⌕'; position:absolute; left:13px; top:50%; transform:translateY(-50%);
    color:var(--ink-soft); font-size:15px;
  }

  /* ---------- GRID ---------- */
  .grid{
    padding:26px 24px 80px;
    display:grid; grid-template-columns:repeat(2, 1fr); gap:18px;
  }
  @media (max-width:720px){ .grid{grid-template-columns:1fr;} }

  .card{
    background:var(--paper-raised);
    border:1px solid var(--line);
    border-radius:var(--radius);
    display:grid; grid-template-columns:10px 1fr;
    box-shadow:0 1px 0 rgba(27,42,34,0.04);
    cursor:pointer;
    opacity:0; transform:translateY(10px);
    animation:rise .5s ease forwards;
  }
  .card:hover{border-color:var(--line-strong);}
  .card .tab{background:var(--tab-color);}
  .card .body{padding:18px 20px 20px;}
  .card-top{display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; gap:10px;}
  .tag{
    font-family:'IBM Plex Mono', monospace; font-size:11px; letter-spacing:0.06em; text-transform:uppercase;
    padding:3px 9px; border-radius:12px;
    background:var(--tab-bg); color:var(--tab-color); font-weight:600;
  }
  .date{font-family:'IBM Plex Mono', monospace; font-size:11.5px; color:var(--ink-soft); white-space:nowrap;}
  .card h3{font-family:'Fraunces', serif; font-size:19px; font-weight:600; margin:0 0 8px; letter-spacing:-0.005em;}
  .card p{font-size:14px; color:var(--ink-soft); margin:0 0 12px;}
  .keywords{display:flex; gap:6px; flex-wrap:wrap;}
  .kw{font-size:11px; font-family:'IBM Plex Mono', monospace; color:var(--ink-soft);}
  .kw::before{content:'#';}

  @keyframes rise{ to{opacity:1; transform:none;} }

  .empty-state{
    padding:60px 24px; text-align:center; color:var(--ink-soft);
    font-family:'IBM Plex Mono', monospace; font-size:13px;
  }

  /* ---------- MODAL ---------- */
  .overlay{
    position:fixed; inset:0; background:rgba(20,28,22,0.55);
    display:none; align-items:flex-start; justify-content:center;
    padding:60px 20px; overflow-y:auto; z-index:100;
  }
  .overlay.open{display:flex;}
  .modal{
    background:var(--paper-raised); max-width:640px; width:100%;
    border-radius:var(--radius); box-shadow:0 20px 50px -10px rgba(0,0,0,0.4);
    display:grid; grid-template-columns:14px 1fr;
    animation:pop .25s ease;
  }
  @keyframes pop{ from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;} }
  .modal .tab{background:var(--tab-color);}
  .modal .body{padding:34px 34px 38px; position:relative;}
  .modal-close{
    position:absolute; top:20px; right:22px; background:none; border:none;
    font-size:22px; color:var(--ink-soft); cursor:pointer; line-height:1;
  }
  .modal-close:hover{color:var(--ink);}
  .modal h2{font-family:'Fraunces', serif; font-size:26px; margin:14px 0 12px; padding-right:20px;}
  .modal .meta-row{display:flex; gap:14px; align-items:center; margin-bottom:6px;}
  .modal-content{font-size:15px; color:var(--ink); line-height:1.7; margin-top:16px;}
  .modal-content p{margin:0 0 14px;}
  .modal-source{margin-top:22px; padding-top:16px; border-top:1px solid var(--line); font-family:'IBM Plex Mono', monospace; font-size:12px; color:var(--ink-soft);}

  /* ---------- FOOTER ---------- */
  footer{
    border-top:1px solid var(--line-strong);
    padding:38px 24px 46px;
    font-size:13.5px; color:var(--ink-soft);
  }
  footer .wrap{display:flex; justify-content:space-between; flex-wrap:wrap; gap:16px;}
  footer .foot-brand{font-family:'IBM Plex Mono', monospace; letter-spacing:0.05em; text-transform:uppercase; font-size:11.5px;}
  footer a{text-decoration:none; border-bottom:1px solid var(--line-strong);}
  footer a:hover{border-bottom-color:var(--ink);}
  .legal-row{
    margin-top:30px; padding-top:18px; border-top:1px solid var(--line);
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;
    font-family:'IBM Plex Mono', monospace; font-size:11.5px; color:var(--ink-soft);
  }
  .legal-links{display:flex; gap:16px; flex-wrap:wrap;}
  .legal-links a{color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.04em;}

  :focus-visible{outline:2px solid var(--c-editing); outline-offset:2px;}

  /* ---------- ADMIN PANEL ---------- */
  .admin-modal{max-width:620px;}
  .admin-form{display:flex; flex-direction:column; gap:16px; margin-top:10px;}
  .admin-form label{
    display:flex; flex-direction:column; gap:6px;
    font-family:'IBM Plex Mono', monospace; font-size:11.5px; letter-spacing:0.04em; text-transform:uppercase;
    color:var(--ink-soft);
  }
  .admin-form input[type="text"], .admin-form select, .admin-form textarea{
    font-family:'IBM Plex Sans', sans-serif; font-size:14px; text-transform:none; letter-spacing:normal;
    color:var(--ink); padding:9px 12px; border:1px solid var(--line-strong); border-radius:var(--radius);
    background:var(--paper); resize:vertical;
  }
  .admin-form input:focus, .admin-form select:focus, .admin-form textarea:focus{
    outline:2px solid var(--c-editing); outline-offset:1px;
  }
  .checkbox-row{flex-direction:row !important; align-items:flex-start; gap:8px !important; text-transform:none; letter-spacing:normal; font-size:13px;}
  .checkbox-row input{margin-top:2px;}
  .generate-btn{
    font-family:'IBM Plex Mono', monospace; font-size:12.5px; text-transform:uppercase; letter-spacing:0.06em;
    background:var(--ink); color:var(--paper); border:none; border-radius:20px;
    padding:11px 20px; cursor:pointer; align-self:flex-start;
  }
  .generate-btn:hover{background:var(--c-editing);}
  .generate-btn.secondary{background:var(--paper-raised); color:var(--ink); border:1px solid var(--line-strong);}
  .generate-btn.secondary:hover{background:var(--paper);}
  #af-output{font-family:'IBM Plex Mono', monospace; font-size:12px; background:#22301F0D;}

  @media (max-width:600px){
    h1.headline{font-size:38px;}
    .site-nav{display:none;}
    .search-wrap{margin-left:0; width:100%;}
    .filter-bar{gap:8px;}
  }
</style>
</head>
<body>

<header class="site">
  <div class="site-bar">
    <div class="brand">
      <div class="brand-mark"></div>
      <div class="brand-text">BioBriefing</div>
    </div>
    <nav class="site-nav">
      <a href="#updates">Latest</a>
      <a href="#" id="nav-genomics">Categories</a>
      <a href="#about">About</a>
      <a href="#" id="nav-admin" style="color:var(--c-editing);">+ Add Update</a>
    </nav>
  </div>
</header>

<section class="hero wrap">
  <div class="eyebrow">Student Edition · Updated Weekly</div>
  <h1 class="headline">Biotechnology, tracked for the classroom.</h1>
  <p class="sub">A running notebook of biotechnology developments — gene editing, vaccines, bioinformatics, funding and careers — written so students can actually use them, not just skim them.</p>
  <div class="hero-meta">
    <span><strong id="stat-count">0</strong> entries logged</span>
    <span><strong id="stat-cats">6</strong> categories tracked</span>
    <span>Curated by <strong>your instructor</strong></span>
  </div>

  <div class="featured" id="featured-card">
    <!-- filled by JS -->
  </div>
</section>

<div class="filter-bar wrap" id="updates">
  <button class="chip active" data-filter="all">All</button>
  <button class="chip" data-filter="genomics">Genomics</button>
  <button class="chip" data-filter="editing">Gene Editing</button>
  <button class="chip" data-filter="vaccines">Vaccines</button>
  <button class="chip" data-filter="bioinfo">Bioinformatics</button>
  <button class="chip" data-filter="careers">Careers</button>
  <button class="chip" data-filter="funding">Funding &amp; Policy</button>
  <div class="search-wrap">
    <input type="text" id="search" placeholder="Search updates…" aria-label="Search updates">
  </div>
</div>

<div class="grid wrap" id="grid"></div>

<div class="overlay" id="overlay">
  <div class="modal" id="modal-inner">
    <div class="tab"></div>
    <div class="body">
      <button class="modal-close" id="modal-close" aria-label="Close">×</button>
      <div id="modal-content"></div>
    </div>
  </div>
</div>

<div class="overlay" id="passcode-overlay">
  <div class="modal admin-modal" style="max-width:380px;">
    <div class="tab" style="background:var(--c-editing);"></div>
    <div class="body">
      <button class="modal-close" id="passcode-close" aria-label="Close">×</button>
      <div class="eyebrow" style="margin-bottom:8px;">Handler tools</div>
      <h2 style="margin-top:4px; font-size:21px;">Enter passcode</h2>
      <div class="admin-form" style="margin-top:14px;">
        <label>Passcode
          <input type="password" id="pc-input" placeholder="••••••••">
        </label>
        <button id="pc-submit" class="generate-btn">Unlock</button>
        <span id="pc-error" style="font-size:12px; color:var(--c-funding); display:none;">Incorrect passcode. Try again.</span>
      </div>
    </div>
  </div>
</div>

<div class="overlay" id="admin-overlay">
  <div class="modal admin-modal">
    <div class="tab" style="background:var(--c-editing);"></div>
    <div class="body">
      <button class="modal-close" id="admin-close" aria-label="Close">×</button>
      <div class="eyebrow" style="margin-bottom:8px;">Handler tools</div>
      <h2 style="margin-top:4px;">Add a New Update</h2>
      <p style="color:var(--ink-soft); font-size:14px; margin:0 0 20px;">
        Fill this in, click <strong>Generate code</strong>, then copy the result into the
        <code>UPDATES</code> array in <code>index.html</code> (either on your computer, or
        directly in GitHub's editor). This box does not publish anything by itself —
        it just writes correctly-formatted code for you.
      </p>

      <div class="admin-form">
        <label>Title
          <input type="text" id="af-title" placeholder="e.g. New CRISPR delivery method shows promise">
        </label>

        <label>Category
          <select id="af-category">
            <option value="genomics">Genomics</option>
            <option value="editing">Gene Editing</option>
            <option value="vaccines">Vaccines</option>
            <option value="bioinfo">Bioinformatics</option>
            <option value="careers">Careers</option>
            <option value="funding">Funding & Policy</option>
          </select>
        </label>

        <label>Date
          <input type="text" id="af-date" placeholder="e.g. Jul 20, 2026">
        </label>

        <label>Excerpt (1–2 sentences, shown on the card)
          <textarea id="af-excerpt" rows="2" placeholder="Short summary for the card view"></textarea>
        </label>

        <label>Full write-up (one paragraph per line)
          <textarea id="af-content" rows="5" placeholder="Paragraph one.&#10;Paragraph two.&#10;Paragraph three."></textarea>
        </label>

        <label>Tags (comma separated)
          <input type="text" id="af-tags" placeholder="e.g. crispr, delivery, vectors">
        </label>

        <label>Source (optional)
          <input type="text" id="af-source" placeholder="e.g. Nature Biotechnology">
        </label>

        <label>Link (optional)
          <input type="text" id="af-link" placeholder="https://...">
        </label>

        <label class="checkbox-row">
          <input type="checkbox" id="af-featured">
          Show this in the featured hero slot (only one update should have this checked)
        </label>

        <button id="af-generate" class="generate-btn">Generate code →</button>

        <div id="af-output-wrap" style="display:none;">
          <label>Copy this into the <code>UPDATES</code> array
            <textarea id="af-output" rows="10" readonly></textarea>
          </label>
          <button id="af-copy" class="generate-btn secondary">Copy to clipboard</button>
          <span id="af-copy-status" style="font-size:12px; color:var(--c-editing); margin-left:10px;"></span>
        </div>
      </div>
    </div>
  </div>
</div>

<footer id="about">
  <div class="wrap">
    <div>
      <div class="foot-brand">BioBriefing</div>
      <div style="margin-top:8px; max-width:40ch;">A shared board for biotechnology updates, kept in one place so students don't have to hunt across ten different feeds before class.</div>
      <div style="margin-top:16px; font-family:'IBM Plex Mono', monospace; font-size:12px;">
        Handled by <strong>Dev Bharat</strong><br>
        <a href="mailto:manojroy9864@gmail.com">manojroy9864@gmail.com</a> · +91 98013 50162
      </div>
    </div>
    <div style="max-width:32ch;">
      Spot something worth adding? Send it to your instructor to include in next week's log.
    </div>
  </div>
  <div class="wrap legal-row">
    <span>© 2026 BioBriefing. Run by Dev Bharat, Patna, Bihar, India.</span>
    <span class="legal-links">
      <a href="#" data-legal="privacy">Privacy Policy</a>
      <a href="#" data-legal="terms">Terms of Use</a>
      <a href="#" data-legal="disclaimer">Disclaimer</a>
      <a href="#" data-legal="grievance">Grievance Contact</a>
    </span>
  </div>
</footer>

<script>
/* =========================================================================
   ADD NEW UPDATES HERE.{
    title: "Prime editing: the 'find-and-replace' tool for DNA, explained",
    category: "editing",
    date: "Jul 14, 2026",
    excerpt: "Prime editing can rewrite a stretch of DNA — not just a single letter — without cutting both strands. Here's how it differs from base editing and classic CRISPR-Cas9.",
    content: [
      "Prime editing combines two things: a Cas9 protein modified so it only nicks one strand of DNA instead of cutting both, and a reverse transcriptase enzyme fused onto it that can write new genetic sequence directly at the target site.",
      "A guide molecule called a pegRNA does double duty here — it directs the complex to the right location in the genome, and also carries the template for the new sequence to be written in.",
      "This matters because base editors (covered in an earlier update) can only swap one DNA letter for another of a specific type. Prime editing can insert, delete, or rewrite a short run of letters, covering a much wider range of mutations without ever making a full double-strand break.",
      "For students: think of the CRISPR toolkit as a spectrum of precision. Cas9 cuts and lets repair machinery take over — powerful but somewhat unpredictable. Base editors swap single letters cleanly. Prime editors go further, acting closer to a genuine 'find and replace' function for DNA. Exam questions often test whether you can match a described mutation to the right tool on this spectrum."
    ],
    tags: ["crispr", "prime-editing", "molecular-biology"],
    source: "Lecture supplement"
  },
   Each entry is one object. Fields:
     title      – headline of the update
     category   – one of: genomics | editing | vaccines | bioinfo | careers | funding
     date       – e.g. "Jul 10, 2026" (shown as-is, sort manually by placing
                  newest entries first in the array)
     excerpt    – 1–2 sentence summary shown on the card
     content    – full write-up shown when the card is clicked. Use an array
                  of strings; each string becomes its own paragraph.
     tags       – array of short keywords shown on the card
     source     – (optional) name of the original source, shown in the modal
     link       – (optional) URL students can open to read the original piece
     featured   – set true on exactly ONE entry to show it in the hero slot
   ========================================================================= */
const UPDATES = [
  {
    title: "CRISPR base editing, explained without the jargon",
    category: "editing",
    date: "Jul 10, 2026",
    excerpt: "Base editors change a single DNA letter without cutting both strands of the helix — a gentler alternative to classic CRISPR-Cas9. Here's the mechanism, in plain terms.",
    content: [
      "Classic CRISPR-Cas9 works by cutting both strands of DNA and letting the cell's own repair machinery patch the break — a process that is powerful but occasionally messy.",
      "Base editors take a different approach. They fuse a Cas9 variant that no longer cuts DNA cleanly to an enzyme that chemically converts one nucleotide into another, letter by letter, without ever breaking the double helix.",
      "For students: focus on the distinction between 'cutting' editors (Cas9, Cas12) and 'rewriting' editors (base editors, prime editors). Exam questions often hinge on which class of tool is appropriate for which type of mutation."
    ],
    tags: ["crispr", "base-editing", "molecular-biology"],
    source: "Lecture supplement",
    featured: true
  },
  {
    title: "mRNA vaccine platforms are moving beyond infectious disease",
    category: "vaccines",
    date: "Jul 8, 2026",
    excerpt: "The lipid-nanoparticle delivery system built for COVID-19 vaccines is now the backbone of trials in oncology and rare disease. What changed, and why it matters for immunology students.",
