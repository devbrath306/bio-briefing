  if(e.key === "Enter") tryUnlock();
});
document.getElementById("passcode-close").addEventListener("click", () => {
  document.getElementById("passcode-overlay").classList.remove("open");
});
document.getElementById("passcode-overlay").addEventListener("click", (e) => {
  if(e.target.id === "passcode-overlay") document.getElementById("passcode-overlay").classList.remove("open");
});
document.getElementById("admin-close").addEventListener("click", () => {
  document.getElementById("admin-overlay").classList.remove("open");
});
document.getElementById("admin-overlay").addEventListener("click", (e) => {
  if(e.target.id === "admin-overlay") document.getElementById("admin-overlay").classList.remove("open");
});

function jsEscape(str){
  return String(str).replace(/\\/g, "\\\\").replace(/"/g, '\\"');
}

document.getElementById("af-generate").addEventListener("click", () => {
  const title = document.getElementById("af-title").value.trim();
  const category = document.getElementById("af-category").value;
  const date = document.getElementById("af-date").value.trim();
  const excerpt = document.getElementById("af-excerpt").value.trim();
  const contentLines = document.getElementById("af-content").value.split("\n").map(l => l.trim()).filter(Boolean);
  const tags = document.getElementById("af-tags").value.split(",").map(t => t.trim()).filter(Boolean);
  const source = document.getElementById("af-source").value.trim();
  const link = document.getElementById("af-link").value.trim();
  const featured = document.getElementById("af-featured").checked;

  if(!title || !date || !excerpt || contentLines.length === 0){
    document.getElementById("af-copy-status").style.color = "var(--c-funding)";
    document.getElementById("af-copy-status").textContent = "Please fill in at least Title, Date, Excerpt, and Full write-up.";
    return;
  }
  document.getElementById("af-copy-status").style.color = "var(--c-editing)";

  let code = `  {\n`;
  code += `    title: "${jsEscape(title)}",\n`;
  code += `    category: "${category}",\n`;
  code += `    date: "${jsEscape(date)}",\n`;
  code += `    excerpt: "${jsEscape(excerpt)}",\n`;
  code += `    content: [\n`;
  code += contentLines.map(l => `      "${jsEscape(l)}"`).join(",\n");
  code += `\n    ],\n`;
  code += `    tags: [${tags.map(t => `"${jsEscape(t)}"`).join(", ")}],\n`;
  if(source) code += `    source: "${jsEscape(source)}",\n`;
  if(link) code += `    link: "${jsEscape(link)}",\n`;
  if(featured) code += `    featured: true,\n`;
  code = code.replace(/,\n$/, "\n");
  code += `  },`;

  document.getElementById("af-output").value = code;
  document.getElementById("af-output-wrap").style.display = "block";
  document.getElementById("af-copy-status").textContent = "";
});

document.getElementById("af-copy").addEventListener("click", () => {
  const output = document.getElementById("af-output");
  output.select();
  navigator.clipboard.writeText(output.value).then(() => {
    document.getElementById("af-copy-status").textContent = "Copied ✓";
  }).catch(() => {
    document.getElementById("af-copy-status").textContent = "Select the text above and copy manually.";
  });
});

renderFeatured();
renderGrid();
</script>

