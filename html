/* =========================================================================
   Below this line is display logic — no need to edit unless you're
   changing how the site behaves.
   ========================================================================= */

const CATEGORY_META = {
  genomics:  { label: "Genomics",         color: "var(--c-genomics)",  bg: "var(--c-genomics-bg)" },
  editing:   { label: "Gene Editing",     color: "var(--c-editing)",   bg: "var(--c-editing-bg)" },
  vaccines:  { label: "Vaccines",         color: "var(--c-vaccines)",  bg: "var(--c-vaccines-bg)" },
  bioinfo:   { label: "Bioinformatics",   color: "var(--c-bioinfo)",   bg: "var(--c-bioinfo-bg)" },
  careers:   { label: "Careers",          color: "var(--c-careers)",  bg: "var(--c-careers-bg)" },
  funding:   { label: "Funding & Policy", color: "var(--c-funding)",  bg: "var(--c-funding-bg)" },
};

let activeFilter = "all";
let searchTerm = "";

function renderFeatured(){
  const item = UPDATES.find(u => u.featured) || UPDATES[0];
  const meta = CATEGORY_META[item.category];
  const el = document.getElementById("featured-card");
  el.style.setProperty("--tab-color", meta.color);
  el.innerHTML = `
    <div class="tab"></div>
    <div class="body">
      <div class="featured-label">
        <span class="pin">★ FEATURED</span>
        <span>${meta.label}</span>
        <span>·</span>
        <span>${item.date}</span>
      </div>
      <h2>${item.title}</h2>
      <p class="excerpt">${item.excerpt}</p>
      <span class="read-link" data-open="${UPDATES.indexOf(item)}">Read full update →</span>
    </div>`;
}

function matchesFilters(item){
  const catOk = activeFilter === "all" || item.category === activeFilter;
  const term = searchTerm.trim().toLowerCase();
  const hay = (item.title + " " + item.excerpt + " " + item.tags.join(" ")).toLowerCase();
  const searchOk = term === "" || hay.includes(term);
  return catOk && searchOk;
}

function renderGrid(){
  const grid = document.getElementById("grid");
  const items = UPDATES.filter(matchesFilters);
  document.getElementById("stat-count").textContent = UPDATES.length;

  if(items.length === 0){
    grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1;">No updates match that search. Try a different term or category.</div>`;
    return;
  }

  grid.innerHTML = items.map(item => {
    const idx = UPDATES.indexOf(item);
    const meta = CATEGORY_META[item.category];
    return `
      <div class="card" style="--tab-color:${meta.color}; --tab-bg:${meta.bg}; animation-delay:${Math.min(idx,8)*0.04}s" data-open="${idx}" tabindex="0" role="button" aria-label="Open update: ${item.title}">
        <div class="tab"></div>
        <div class="body">
          <div class="card-top">
            <span class="tag">${meta.label}</span>
            <span class="date">${item.date}</span>
          </div>
          <h3>${item.title}</h3>
          <p>${item.excerpt}</p>
          <div class="keywords">${item.tags.map(t => `<span class="kw">${t}</span>`).join("")}</div>
        </div>
      </div>`;
  }).join("");
}

function openModal(idx){
  const item = UPDATES[idx];
  const meta = CATEGORY_META[item.category];
  document.getElementById("modal-inner").style.setProperty("--tab-color", meta.color);
  document.getElementById("modal-content").innerHTML = `
    <div class="meta-row">
      <span class="tag">${meta.label}</span>
      <span class="date">${item.date}</span>
    </div>
    <h2>${item.title}</h2>
    <div class="modal-content">
      ${item.content.map(p => `<p>${p}</p>`).join("")}
    </div>
    ${item.source ? `<div class="modal-source">Source: ${item.source}${item.link ? ` · <a href="${item.link}" target="_blank" rel="noopener">Open original ↗</a>` : ""}</div>` : ""}
  `;
  document.getElementById("overlay").classList.add("open");
}

function closeModal(){
  document.getElementById("overlay").classList.remove("open");
}

document.addEventListener("click", (e) => {
  const opener = e.target.closest("[data-open]");
  if(opener){ openModal(Number(opener.dataset.open)); return; }
  const legalLink = e.target.closest("[data-legal]");
  if(legalLink){ e.preventDefault(); openLegal(legalLink.dataset.legal); return; }
  if(e.target.id === "overlay"){ closeModal(); }
  if(e.target.id === "modal-close"){ closeModal(); }
});
document.addEventListener("keydown", (e) => { if(e.key === "Escape") closeModal(); });

document.querySelectorAll(".chip").forEach(chip => {
  chip.addEventListener("click", () => {
    document.querySelectorAll(".chip").forEach(c => c.classList.remove("active"));
    chip.classList.add("active");
    activeFilter = chip.dataset.filter;
    renderGrid();
  });
});

document.getElementById("search").addEventListener("input", (e) => {
  searchTerm = e.target.value;
  renderGrid();
});

document.getElementById("nav-genomics").addEventListener("click", (e) => {
  e.preventDefault();
  document.getElementById("updates").scrollIntoView({behavior:"smooth"});
});

